///|
pub fn compute_orientation(img : GrayImage, kp : Keypoint) -> Double {
  let patch_radius = 15
  let mut m01 = 0.0
  let mut m10 = 0.0

  let mut dy = -patch_radius
  while dy <= patch_radius {
    let mut dx = -patch_radius
    while dx <= patch_radius {
      if dx * dx + dy * dy <= patch_radius * patch_radius {
        let val = Double::from_int(img.get(kp.x + dx, kp.y + dy))
        m10 = m10 + Double::from_int(dx) * val
        m01 = m01 + Double::from_int(dy) * val
      }
      dx = dx + 1
    }
    dy = dy + 1
  }

  if m10 == 0.0 && m01 == 0.0 {
    return 0.0
  }

  let abs_x = if m10 < 0.0 { -m10 } else { m10 }
  let abs_y = if m01 < 0.0 { -m01 } else { m01 }

  let mut angle = 0.0
  if abs_x >= abs_y {
    let ratio = m01 / m10
    angle = ratio - ratio * ratio * ratio / 3.0
    if m10 < 0.0 {
      if m01 >= 0.0 {
        angle = angle + 3.141592653589793
      } else {
        angle = angle - 3.141592653589793
      }
    }
  } else {
    let ratio = m10 / m01
    angle = ratio - ratio * ratio * ratio / 3.0
    if m01 >= 0.0 {
      angle = 1.5707963267948966 - angle
    } else {
      angle = -1.5707963267948966 - angle
    }
  }
  angle
}

///|
pub fn compute_orb_descriptors(
  img : GrayImage,
  kps : Array[Keypoint],
) -> (Array[Keypoint], Array[Descriptor]) {
  let valid_kps : Array[Keypoint] = []
  let descriptors : Array[Descriptor] = []
  let border = 16

  let mut idx = 0
  while idx < kps.length() {
    let kp = kps[idx]
    if kp.x >= border &&
      kp.x < img.width - border &&
      kp.y >= border &&
      kp.y < img.height - border {
      let angle = compute_orientation(img, kp)
      let oriented_kp = Keypoint::new(kp.x, kp.y, kp.response, angle)

      // Taylor expansion approximation for cos/sin in Double
      let mut a = angle
      while a > 3.141592653589793 {
        a = a - 6.283185307179586
      }
      while a < -3.141592653589793 {
        a = a + 6.283185307179586
      }
      let a2 = a * a
      let cos_a = 1.0 - a2 / 2.0 + a2 * a2 / 24.0
      let sin_a = a - a2 * a / 6.0 + a2 * a2 * a / 120.0

      let desc = Descriptor::new(32)

      let mut pair_idx = 0
      while pair_idx < 256 {
        let (ax, ay, bx, by) = orb_pattern[pair_idx]

        let fax = Double::from_int(ax)
        let fay = Double::from_int(ay)
        let fbx = Double::from_int(bx)
        let fby = Double::from_int(by)

        let rx_a = (fax * cos_a - fay * sin_a + 0.5).to_int()
        let ry_a = (fax * sin_a + fay * cos_a + 0.5).to_int()

        let rx_b = (fbx * cos_a - fby * sin_a + 0.5).to_int()
        let ry_b = (fbx * sin_a + fby * cos_a + 0.5).to_int()

        let val_a = img.get(oriented_kp.x + rx_a, oriented_kp.y + ry_a)
        let val_b = img.get(oriented_kp.x + rx_b, oriented_kp.y + ry_b)

        if val_a < val_b {
          let byte_idx = pair_idx / 8
          let bit_idx = pair_idx % 8
          let current_byte = desc.data[byte_idx].to_int()
          let updated_byte = current_byte | (1 << bit_idx)
          desc.data[byte_idx] = updated_byte.to_byte()
        }

        pair_idx = pair_idx + 1
      }

      valid_kps.push(oriented_kp)
      descriptors.push(desc)
    }
    idx = idx + 1
  }

  (valid_kps, descriptors)
}
